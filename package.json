    "prisma": "^5.21.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "git-commit-msg-linter": "^4.11.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
