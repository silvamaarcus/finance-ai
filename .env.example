# ============================================================
# Banco de dados — Neon (PostgreSQL serverless) ou Docker local
# Neon:   postgresql://<user>:<password>@<host>/<db>?sslmode=require
# Docker: postgresql://postgres:password@localhost:5432/finance-ai
# ============================================================
DATABASE_URL=""

# ============================================================
# Clerk — Autenticação
# Obtenha em: https://dashboard.clerk.com → API Keys
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# URL de redirecionamento após login
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"

# ============================================================
# Stripe — Pagamentos
# Obtenha em: https://dashboard.stripe.com → Developers → API Keys
# ============================================================
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Price ID do plano premium (ex: price_xxxxxxxxxxxxxxxx)
# Crie em: Stripe Dashboard → Product catalog → Add product
STRIPE_PREMIUM_PLAN_PRICE_ID=""

# Webhook secret — gerado ao rodar: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# ============================================================
# Groq — IA para geração de relatórios financeiros
# Obtenha em: https://console.groq.com → API Keys
# ============================================================
GROQ_API_KEY=""

# ============================================================
# URL pública da aplicação
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
